<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml;base64,">
<title>Install {{ package_name }}</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:        #f8f9fa;
    --surface:   #ffffff;
    --border:    #dee2e6;
    --text:      #212529;
    --muted:     #6c757d;
    --hover-bg:  #f1f3f5;
    --gpg-bg:    #f1f3f5;
    --gpg-text:  #495057;
    --link:      #0d6efd;
    --footer:    #adb5bd;
    --toggle-bg: #e9ecef;
  }
  [data-theme="dark"] {
    --bg:        #0f1117;
    --surface:   #1a1d27;
    --border:    #2e3240;
    --text:      #e2e4eb;
    --muted:     #7c8196;
    --hover-bg:  #22263a;
    --gpg-bg:    #22263a;
    --gpg-text:  #a0a8c0;
    --link:      #5b9cf6;
    --footer:    #4a5068;
    --toggle-bg: #22263a;
  }

  body {
    font-family: system-ui, -apple-system, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.5;
    padding: 2rem 1rem;
    transition: background .2s, color .2s;
  }
  .container { max-width: 900px; margin: 0 auto; }

  header { margin-bottom: 2.5rem; position: relative; }
  header h1 { font-size: 2rem; margin: .5rem 0 .25rem; }
  header blockquote {
    color: var(--muted); font-style: italic;
    border-left: 3px solid var(--border);
    padding-left: .75rem; margin: .5rem 0;
    max-width: 400px; text-align: left;
  }
  header blockquote a { color: var(--link); }

  .theme-toggle {
    position: absolute; top: 0; right: 0;
    display: flex; background: var(--toggle-bg);
    border-radius: 20px; padding: 3px; gap: 2px;
    border: 1px solid var(--border);
    transition: background .2s, border-color .2s;
  }
  .theme-toggle button {
    background: none; border: none; border-radius: 16px;
    padding: 4px 8px; font-size: .75rem; cursor: pointer;
    color: var(--muted); transition: background .15s, color .15s; line-height: 1;
  }
  .theme-toggle button.active {
    background: var(--surface); color: var(--text);
    box-shadow: 0 1px 3px rgba(0,0,0,.15);
  }

  .family-group {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-top: 1.75rem;
  }
  .family-title {
    font-size: 1rem;
    font-weight: 700;
    margin: 0 0 .75rem;
    color: var(--text);
  }
  .family-logo {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    margin-top: .35rem;
    color: var(--text);
  }
  .family-logo svg { width: 100%; height: 100%; display: block; }
  .family-accordions { flex: 1; min-width: 0; }

  .accordion {
    border: 1px solid var(--border);
    border-radius: 8px; overflow: hidden;
    margin-bottom: .5rem; background: var(--surface);
    transition: background .2s, border-color .2s;
  }
  .accordion-header {
    display: flex; justify-content: space-between; align-items: center;
    padding: .85rem 1.1rem; cursor: pointer; user-select: none;
    font-weight: 600; font-size: .95rem; transition: background .15s;
  }
  .accordion-header:hover { background: var(--hover-bg); }
  .accordion-header .chevron {
    width: 16px; height: 16px; flex-shrink: 0;
    transition: transform .3s ease; color: var(--muted);
  }
  .accordion.open > .accordion-header .chevron { transform: rotate(180deg); }

  .accordion-body {
    display: grid; grid-template-rows: 0fr;
    transition: grid-template-rows .3s ease;
  }
  .accordion.open > .accordion-body { grid-template-rows: 1fr; }
  .accordion-inner {
    overflow: hidden; padding: 0 1.1rem;
    transition: padding .3s ease;
  }
  .accordion.open > .accordion-body > .accordion-inner { padding: 0 1.1rem 1.1rem; }

  .step-label {
    font-size: .7rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: .06em; color: var(--muted);
    margin-bottom: .35rem; margin-top: .9rem;
  }

  .code-block {
    display: flex; align-items: flex-start;
    background: #1e1e2e; color: #cdd6f4; border-radius: 6px;
    font-family: ui-monospace, 'Fira Code', monospace;
    font-size: .8rem; line-height: 1.6;
  }
  .code-block .code-scroll {
    flex: 1; overflow-x: auto; padding: .85rem 1rem; white-space: pre;
  }
  .copy-btn {
    flex-shrink: 0; align-self: flex-start;
    margin: .5rem .5rem 0 0; background: #313244;
    border: none; color: #cdd6f4; border-radius: 4px;
    padding: .25rem .6rem; font-size: .7rem; cursor: pointer;
    transition: background .15s;
  }
  .copy-btn:hover { background: #45475a; }
  .copy-btn.copied { background: #a6e3a1; color: #1e1e2e; }

  .gpg-toggle {
    display: inline-flex; align-items: center; gap: .35rem;
    margin-top: .9rem; background: none;
    border: 1px solid var(--border); border-radius: 4px;
    padding: .2rem .6rem; font-size: .7rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: .06em;
    color: var(--muted); cursor: pointer;
    transition: background .15s, border-color .15s;
  }
  .gpg-toggle:hover { background: var(--hover-bg); }
  .gpg-toggle .gpg-chevron { width: 12px; height: 12px; transition: transform .25s ease; }
  .gpg-toggle.open .gpg-chevron { transform: rotate(180deg); }

  .gpg-body { display: grid; grid-template-rows: 0fr; transition: grid-template-rows .25s ease; }
  .gpg-body.open { grid-template-rows: 1fr; }
  .gpg-inner { overflow: hidden; }
  .gpg-block {
    background: var(--gpg-bg); border-radius: 6px; padding: .75rem 1rem;
    font-family: ui-monospace, monospace; font-size: .75rem;
    color: var(--gpg-text); white-space: pre; overflow-x: auto;
    margin-top: .35rem; transition: background .2s, color .2s;
  }

  .download-label { font-size: .8rem; color: var(--muted); margin-top: .85rem; display: block; }
  .download-link  { font-size: .85rem; display: inline-block; color: var(--link); }

  footer { text-align: center; margin-top: 2.5rem; color: var(--footer); font-size: .8rem; }
  footer a { color: var(--footer); }

  .acc-footer-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .acc-timestamp {
    font-size: .75rem;
    color: var(--muted);
  }

  .no-js-warning {
      background: #ffdddd;
      color: #900;
      padding: 1rem;
      border: 1px solid #900;
      margin: 1rem 0;
      font-family: sans-serif;
    }
</style>
</head>
<body>
<div class="container">
  <noscript>
    <div class="no-js-warning">
      This page requires JavaScript to work properly
    </div>
  </noscript>

  <header>
    <div class="theme-toggle" id="themeToggle">
      <button data-mode="light" title="Light">☀ Light</button>
      <button data-mode="auto"  title="Auto">⚙ Auto</button>
      <button data-mode="dark"  title="Dark">🌙 Dark</button>
    </div>
    <h1>📦 Install {{ package_name }}</h1>
    <blockquote>
      {{ description }}<br>
      <a href="{{ homepage }}" target="_blank">{{ homepage }}</a>
    </blockquote>
  </header>
  <div id="root"></div>
  <footer>Powered by <a href="https://omnipackage.org" target="_blank">OmniPackage</a></footer>
</div>

<template id="tpl-accordion">
  <div class="accordion">
    <div class="accordion-header">
      <span class="acc-name"></span>
      <svg class="chevron" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="4 6 8 10 12 6"/>
      </svg>
    </div>
    <div class="accordion-body">
      <div class="accordion-inner">
        <div class="step-label">Installation steps</div>
        <div class="code-block">
          <span class="code-scroll acc-steps"></span>
          <button class="copy-btn">Copy</button>
        </div>
        <button class="gpg-toggle">
          GPG key
          <svg class="gpg-chevron" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="4 6 8 10 12 6"/>
          </svg>
        </button>
        <div class="gpg-body">
          <div class="gpg-inner">
            <div class="gpg-block acc-gpg"></div>
          </div>
        </div>

        <span class="download-label">Or download package directly:</span>
        <div class="acc-footer-row">
          <a class="download-link acc-download" href="#"></a>
          <span class="acc-timestamp"></span>
        </div>
      </div>
    </div>
  </div>
</template>

<script type="application/json" id="data">
[]
</script>

<script>
const mq = window.matchMedia('(prefers-color-scheme: dark)');
function applyTheme(mode) {
  const dark = mode === 'dark' || (mode === 'auto' && mq.matches);
  document.documentElement.dataset.theme = dark ? 'dark' : '';
  document.querySelectorAll('#themeToggle button').forEach(b =>
    b.classList.toggle('active', b.dataset.mode === mode));
}
let currentMode = localStorage.getItem('theme') || 'auto';
applyTheme(currentMode);
document.getElementById('themeToggle').addEventListener('click', e => {
  const b = e.target.closest('button[data-mode]');
  if (!b) return;
  currentMode = b.dataset.mode;
  localStorage.setItem('theme', currentMode);
  applyTheme(currentMode);
});
mq.addEventListener('change', () => { if (currentMode === 'auto') applyTheme('auto'); });

const distros  = JSON.parse(document.getElementById('data').textContent);
const template = document.getElementById('tpl-accordion');
const root     = document.getElementById('root');


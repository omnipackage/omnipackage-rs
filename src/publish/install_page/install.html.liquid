function renderAccordion(distro) {
  const node = template.content.cloneNode(true);
  const acc  = node.querySelector('.accordion');
  const pkg  = distro.download_url.split('/').pop();

  acc.querySelector('.acc-name').textContent     = distro.distro_name;
  acc.querySelector('.acc-steps').textContent    = distro.install_steps;
  acc.querySelector('.acc-download').href        = distro.download_url;
  acc.querySelector('.acc-download').textContent = pkg;

  // Some package types (e.g. AppImage) have no GPG key; drop the GPG section entirely.
  if (distro.gpg_key) {
    acc.querySelector('.acc-gpg').textContent = distro.gpg_key;
  } else {
    acc.querySelector('.gpg-toggle')?.remove();
    acc.querySelector('.gpg-body')?.remove();
  }

  acc.querySelector('.accordion-header').addEventListener('click', () =>
    acc.classList.toggle('open'));

  acc.querySelector('.copy-btn').addEventListener('click', e => {
    e.stopPropagation();
    const btn = e.currentTarget;
    navigator.clipboard.writeText(distro.install_steps).then(() => {
      btn.textContent = 'Copied!';
      btn.classList.add('copied');
      setTimeout(() => { btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 1800);
    });
  });

  const gpgBtn  = acc.querySelector('.gpg-toggle');
  const gpgBody = acc.querySelector('.gpg-body');
  if (gpgBtn && gpgBody) {
    gpgBtn.addEventListener('click', () => {
      const open = gpgBody.classList.toggle('open');
      gpgBtn.classList.toggle('open', open);
    });
  }

  if (distro.timestamp) {
    const el = acc.querySelector('.acc-timestamp');
    el.textContent = 'Updated ' + timeAgo(distro.timestamp);
    el.title = distro.timestamp;
  }

  return acc;
}

const familyOrder = [];
const byFamily = {};

distros.forEach(d => {
  const family = d.distro_family;
  if (!byFamily[family]) {
    familyOrder.push(family);
    byFamily[family] = [];
  }
  byFamily[family].push(d);
});

familyOrder.forEach(family => {
  const group = document.createElement('div');
  group.className = 'family-group';

  const title = document.createElement('h2');
  title.className = 'family-title';
  title.textContent = family;

  const logo = document.createElement('div');
  logo.className = 'family-logo';
  logo.setAttribute('aria-label', family + ' logo');
  logo.innerHTML = FAMILY_LOGOS[family] || FALLBACK_LOGO;

  const col = document.createElement('div');
  col.className = 'family-accordions';
  byFamily[family].forEach(d => col.appendChild(renderAccordion(d)));

  // group.appendChild(title);
  group.appendChild(logo);
  group.appendChild(col);
  root.appendChild(group);
});

function timeAgo(iso) {
  const secs = Math.floor((Date.now() - new Date(iso)) / 1000);
  if (secs < 60) return 'just now';
  const m = Math.floor(secs / 60);
  if (m < 60) return m + ' minute' + (m > 1 ? 's' : '') + ' ago';
  const h = Math.floor(m / 60);
  if (h < 24) return h + ' hour' + (h > 1 ? 's' : '') + ' ago';
  const d = Math.floor(h / 24);
  if (d < 30) return d + ' day' + (d > 1 ? 's' : '') + ' ago';
  const mo = Math.floor(d / 30);
  if (mo < 12) return mo + ' month' + (mo > 1 ? 's' : '') + ' ago';
  const y = Math.floor(mo / 12);
  return y + ' year' + (y > 1 ? 's' : '') + ' ago';
}

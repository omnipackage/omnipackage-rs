#!/bin/sh
# Generated by OmniPackage. Installs {{ package_name }} from its package repository.
set -eu

PKG='{{ package_name }}'
BASE='{{ repo_base_url }}'
REPO_ARCH='{{ repo_arch }}'

ASSUME_YES=0
OVERRIDE_DISTRO=''

err() { echo "install.sh: $*" >&2; exit 1; }

usage() {
  cat <<EOF
Install $PKG from its OmniPackage repository ($REPO_ARCH).

Usage: curl -fsSL $BASE/install.sh | sh -s -- [OPTIONS]

Options:
  -y, --yes          install without asking for confirmation
      --distro <id>  override distro detection (e.g. ubuntu_24.04)
  -h, --help         show this help
EOF
}

while [ $# -gt 0 ]; do
  case "$1" in
    -y|--yes) ASSUME_YES=1 ;;
    --distro) shift; [ $# -gt 0 ] || err "--distro requires an argument"; OVERRIDE_DISTRO="$1" ;;
    --distro=*) OVERRIDE_DISTRO="${1#*=}" ;;
    -h|--help) usage; exit 0 ;;
    *) err "unknown option: $1 (try --help)" ;;
  esac
  shift
done

machine="$(uname -m)"
case "$machine" in
  x86_64|amd64) host_arch=x86_64 ;;
  aarch64|arm64) host_arch=aarch64 ;;
  *) err "unsupported CPU architecture: $machine" ;;
esac
if [ "$host_arch" != "$REPO_ARCH" ]; then
  err "this installer targets $REPO_ARCH, but this machine is $host_arch; use the $host_arch repository's install command instead"
fi

if [ -n "$OVERRIDE_DISTRO" ]; then
  DISTRO="$OVERRIDE_DISTRO"
else
  [ -r /etc/os-release ] || err "cannot read /etc/os-release; re-run with --distro <id>"
  . /etc/os-release
  id="${ID:-}"
  ver="${VERSION_ID:-}"
  case "$id" in
    ubuntu|debian|fedora) DISTRO="${id}_${ver}" ;;
    opensuse-leap) DISTRO="opensuse_${ver}" ;;
    opensuse-tumbleweed) DISTRO="opensuse_tumbleweed" ;;
    almalinux) DISTRO="almalinux_${ver%%.*}" ;;
    rocky) DISTRO="rockylinux_${ver%%.*}" ;;
    mageia) DISTRO="mageia_${ver}" ;;
    arch) DISTRO="arch" ;;
    manjaro) DISTRO="manjaro" ;;
    *) err "cannot map this system (ID='$id') to a distro; re-run with --distro <id>" ;;
  esac
  case "$DISTRO" in
    *_) err "cannot detect the version of '$id'; re-run with --distro <id>" ;;
  esac
fi

STEPS=''
case "$DISTRO" in
{{ steps_case }}
  *) err "'$DISTRO' is not available in this repository ($BASE). Supported: {{ supported_ids }}" ;;
esac

printf '%s will be installed on %s (%s) with:\n\n%s\n\n' "$PKG" "$DISTRO" "$REPO_ARCH" "$STEPS"

NEED_SUDO=0
if [ "$(id -u)" -ne 0 ]; then
  echo "install.sh: installing $PKG requires root privileges."
  command -v sudo >/dev/null 2>&1 || err "root privileges are required and sudo is not available; re-run this script as root"
  NEED_SUDO=1
fi

if [ "$ASSUME_YES" -ne 1 ]; then
  if [ "$NEED_SUDO" -eq 1 ]; then
    prompt='Install as root via sudo? [y/N] '
  else
    prompt='Proceed? [y/N] '
  fi
  if { printf '%s' "$prompt" >/dev/tty && read -r ans </dev/tty; } 2>/dev/null; then
    case "$ans" in
      y|Y|yes|YES) ;;
      *) err "aborted" ;;
    esac
  else
    err "no terminal available for confirmation; re-run with -y to install non-interactively"
  fi
fi

if [ "$NEED_SUDO" -eq 1 ]; then
  printf '%s\n' "$STEPS" | sudo sh
else
  printf '%s\n' "$STEPS" | sh
fi
echo "install.sh: $PKG installed."

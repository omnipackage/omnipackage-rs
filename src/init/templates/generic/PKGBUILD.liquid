# PKGBUILD template rendered at build time. {{ vars }} come from config.yml.
# Fill in the build() and package() functions for your project.
# Maintainer: {{ maintainer }}
pkgname={{ package_name }}
pkgver={{ version }}
pkgrel=1
pkgdesc="{{ description }}"
arch=('x86_64')
url="{{ homepage }}"
license=('GPL-3.0-or-later')
{% if runtime_dependencies.size > 0 %}depends=({{ runtime_dependencies | join: ' ' }}){% endif %}
source=("{{ source_folder_name }}.tar.gz")
sha256sums=('SKIP')

build() {
  cd "$srcdir/{{ source_folder_name }}"
  # TODO: build commands (e.g. `make`, `cargo build --release`).
  make
}

package() {
  cd "$srcdir/{{ source_folder_name }}"
  # TODO: install into "$pkgdir". Example:
  #   install -Dm755 my-binary "$pkgdir/usr/bin/__INIT_PACKAGE_NAME__"
  make install INSTALL_ROOT="$pkgdir"
}

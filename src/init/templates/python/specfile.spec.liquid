# RPM spec template rendered at build time. Real install logic lives in
# .omnipackage/install.sh — edit that to match your project layout.
Name:       {{ package_name }}
Version:    {{ version }}
Release:    1%{?dist}
Summary:    {{ description }}
License:    GPL-3.0-or-later
URL:        {{ homepage }}
Source0:    {{ source_folder_name }}.tar.gz
Vendor:     OmniPackage

BuildRequires: {{ build_dependencies | join: ' ' }}
{% if runtime_dependencies.size > 0 %}
Requires: {{ runtime_dependencies | join: ', ' }}
{% endif %}

%define debug_package %{nil}
%define _build_id_links none

%description
{{ description }}


%prep
%setup -q


%build


%install
chmod +x .omnipackage/install.sh
.omnipackage/install.sh %{buildroot}


%files
%attr(755, root, root) /usr/bin/__INIT_PACKAGE_NAME__
%attr(755, root, root) /usr/lib/__INIT_PACKAGE_NAME__/

%changelog
* __INIT_TODAY__ {{ maintainer }}
- Initial package release

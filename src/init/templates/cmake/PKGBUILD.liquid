# PKGBUILD template rendered at build time. {{ vars }} come from config.yml.
# Adjust install paths for any additional resources your CMake project
# installs (icons, .desktop files).
# Maintainer: {{ maintainer }}
pkgname={{ package_name }}
pkgver={{ version }}
pkgrel=1
pkgdesc="{{ description }}"
arch=('x86_64')
url="{{ homepage }}"
license=('GPL-3.0-or-later')
{% if runtime_dependencies.size > 0 %}depends=({{ runtime_dependencies | join: ' ' }}){% endif %}
source=("{{ source_folder_name }}.tar.gz")
sha256sums=('SKIP')

build() {
  cd "$srcdir/{{ source_folder_name }}"
  cmake -B build -DCMAKE_INSTALL_PREFIX=/usr -DCMAKE_BUILD_TYPE=Release
  make -C build
}

package() {
  cd "$srcdir/{{ source_folder_name }}"
  make -C build install DESTDIR="$pkgdir"
}

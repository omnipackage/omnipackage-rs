# RPM spec template rendered at build time. Adjust install paths for any
# additional resources your CMake project installs (icons, .desktop files).
Name:       {{ package_name }}
Version:    {{ version }}
Release:    1%{?dist}
Summary:    {{ description }}
License:    GPL-3.0-or-later
URL:        {{ homepage }}
Source0:    {{ source_folder_name }}.tar.gz
Vendor:     OmniPackage

BuildRequires: {{ build_dependencies | join: ' ' }}
{% if runtime_dependencies.size > 0 %}
Requires: {{ runtime_dependencies | join: ', ' }}
{% endif %}

%define debug_package %{nil}
%define _build_id_links none

%description
{{ description }}


%prep
%setup -q


%build
mkdir -p build
cd build
cmake .. -DCMAKE_INSTALL_PREFIX=/usr -DCMAKE_BUILD_TYPE=Release
make %{?_smp_mflags}


%install
cd build
make install DESTDIR=%{buildroot}


%files
%attr(755, root, root) /usr/bin/__INIT_PACKAGE_NAME__


%changelog
* __INIT_TODAY__ {{ maintainer }}
- Initial package release

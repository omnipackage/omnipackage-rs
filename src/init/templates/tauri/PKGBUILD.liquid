# PKGBUILD template for a Tauri app. Provide <pkg>.desktop and an icons/
# tree at the repo root. {{ vars }} come from config.yml.
# Maintainer: {{ maintainer }}
pkgname={{ package_name }}
pkgver={{ version }}
pkgrel=1
pkgdesc="{{ description }}"
arch=("$(uname -m)")
url="{{ homepage }}"
license=('GPL-3.0-or-later')
{% if runtime_dependencies.size > 0 %}depends=({{ runtime_dependencies | join: ' ' }}){% endif %}
# makepkg defaults LTO on; disable it — breaks linking prebuilt C/asm (e.g. aws-lc-rs/ring).
options=('!lto')
source=("{{ source_folder_name }}.tar.gz")
sha256sums=('SKIP')

build() {
  cd "$srcdir/{{ source_folder_name }}"
  cargo install tauri-cli --version '^2.0.0'
  cargo tauri build --no-bundle
}

package() {
  cd "$srcdir/{{ source_folder_name }}"
  install -Dm755 src-tauri/target/release/__INIT_PACKAGE_NAME__ "$pkgdir/usr/bin/__INIT_PACKAGE_NAME__"
  install -Dm644 __INIT_PACKAGE_NAME__.desktop "$pkgdir/usr/share/applications/__INIT_PACKAGE_NAME__.desktop"
  mkdir -p "$pkgdir/usr/share/"
  cp -R icons "$pkgdir/usr/share/"
}

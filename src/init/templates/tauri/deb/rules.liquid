#!/usr/bin/make -f
# debian.rules — Debian build rules for a Tauri app. Indents are TABS.
# -*- makefile -*-

export DESTROOT=$(CURDIR)/debian/{{ package_name }}
# export DH_VERBOSE=1

%:
	dh $@ --parallel

override_dh_auto_build:
	cargo install tauri-cli --version '^2.0.0'
	cargo tauri build --no-bundle

override_dh_auto_install:
	install -d -m755 $(DESTROOT)/usr/bin/
	install -m755 src-tauri/target/release/{{ package_name }} $(DESTROOT)/usr/bin/{{ package_name }}
	mkdir -p $(DESTROOT)/usr/share/applications/
	cp {{ package_name }}.desktop $(DESTROOT)/usr/share/applications/
	mkdir -p $(DESTROOT)/usr/share/
	cp -R icons $(DESTROOT)/usr/share/

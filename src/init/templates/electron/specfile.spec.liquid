# RPM spec template rendered at build time. The actual file copying lives in
# .omnipackage/install.sh — edit that to match your project's structure
# (rename .desktop file, change icon paths, etc.).
Name:       {{ package_name }}
Version:    {{ version }}
Release:    1%{?dist}
Summary:    {{ description }}
License:    GPL-3.0-or-later
URL:        {{ homepage }}
Source0:    {{ source_folder_name }}.tar.gz
Vendor:     OmniPackage

BuildRequires: {{ build_dependencies | join: ' ' }}
{% if runtime_dependencies.size > 0 %}
Requires: {{ runtime_dependencies | join: ', ' }}
{% endif %}

%define debug_package %{nil}
%define _build_id_links none

%description
{{ description }}


%prep
%setup -q


%build


%install
.omnipackage/install.sh %{buildroot}


%files
%attr(755, root, root) /usr/bin/__INIT_PACKAGE_NAME__
%attr(755, root, root) /usr/lib/__INIT_PACKAGE_NAME__/
%attr(644, root, root) /usr/share/applications/__INIT_PACKAGE_NAME__.desktop
%attr(644, root, root) /usr/share/icons/hicolor/32x32/apps/__INIT_PACKAGE_NAME__.png
%attr(644, root, root) /usr/share/icons/hicolor/128x128/apps/__INIT_PACKAGE_NAME__.png
%attr(644, root, root) /usr/share/icons/hicolor/256x256/apps/__INIT_PACKAGE_NAME__.png

%changelog
* __INIT_TODAY__ {{ maintainer }}
- Initial package release

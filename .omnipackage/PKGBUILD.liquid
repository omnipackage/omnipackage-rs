# PKGBUILD for omnipackage itself. Rendered at build time.
# Maintainer: {{ maintainer }}
pkgname={{ package_name }}
pkgver={{ version }}
pkgrel=1
pkgdesc="{{ description }}"
arch=('x86_64')
url="{{ homepage }}"
license=('GPL-3.0-or-later')
{% if runtime_dependencies.size > 0 %}depends=({{ runtime_dependencies | join: ' ' }}){% endif %}
optdepends=('docker: alternative container runtime (instead of podman)')
# makepkg defaults LTO on; disable it — breaks linking prebuilt C/asm (e.g. aws-lc-rs/ring).
options=('!lto')
source=("{{ source_folder_name }}.tar.gz")
sha256sums=('SKIP')

build() {
  cd "$srcdir/{{ source_folder_name }}"
  PACKAGE_VERSION="{{ version }}" cargo build --release
}

package() {
  cd "$srcdir/{{ source_folder_name }}"
  install -Dm755 target/release/omnipackage "$pkgdir/usr/bin/omnipackage"
}
